# StatusZap local/deploy environment

# Shared
COMPOSE_PROJECT_NAME=statuszap
SPRING_PROFILES_ACTIVE=dev

# PostgreSQL
POSTGRES_DB=statuszap
POSTGRES_USER=statuszap
POSTGRES_PASSWORD=statuszap_dev_password
DB_URL=jdbc:postgresql://db:5432/statuszap
DB_USER=statuszap
DB_PASS=statuszap_dev_password

# Backend
PORT=8080
JWT_SECRET=change-me-use-at-least-32-random-characters
JWT_EXPIRATION_MS=86400000
DDL_AUTO=update
SHOW_SQL=false
LOG_LEVEL=INFO
APP_LOG_LEVEL=INFO
HEALTH_SHOW_DETAILS=never
STORAGE_DIR=/app/uploads
STORAGE_URL=http://localhost:8080/uploads

# Frontend/CORS
FRONT_URL=http://localhost:4200
API_URL=http://localhost:8080
VITE_API_URL=http://localhost:8080/api
VITE_APP_URL=http://localhost:4200

# Mercado Pago
MP_ENABLED=false
MP_SANDBOX=true
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=
MP_BASE_URL=https://api.mercadopago.com
MP_PLAN_CODE=premium_monthly
MP_PLAN_REASON=Assinatura Premium Mensal
MP_AMOUNT=29.00
MP_CURRENCY=BRL
MP_BACK_URL=http://localhost:4200/billing/mercado-pago
MP_NOTIFICATION_URL=
